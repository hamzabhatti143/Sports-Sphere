# Database Configuration
# PostgreSQL (recommended for production):
DATABASE_URL=postgresql://sportspot:sportspot@localhost:5432/sportspot

# SQLite (for local development):
# DATABASE_URL=sqlite:///./sportspot.db

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Interactive API docs (/docs, /redoc, /openapi.json). Enabled here for local dev;
# leave this unset in production (e.g. the Hugging Face Space) to hide the schema.
ENABLE_DOCS=1
