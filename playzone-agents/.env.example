# --- OpenAI (GPT-4o Vision for payment verification) ---
OPENAI_API_KEY=your_openai_key_here

# --- Database: the SAME Neon Postgres the FastAPI backend uses ---
# Copy DATABASE_URL from ../backend/.env so the bot and website share one DB.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Redis (conversation cache + Bull hold-expiry queue) ---
REDIS_URL=redis://localhost:6379

# --- Server ---
PORT=3000

# Optional: skip WhatsApp client on boot (useful for running just the admin API / migration)
DISABLE_WHATSAPP=false
