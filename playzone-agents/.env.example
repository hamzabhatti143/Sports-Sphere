# --- OpenAI (GPT-4o Vision for payment verification) ---
OPENAI_API_KEY=your_openai_key_here

# --- Database: the SAME Neon Postgres the FastAPI backend uses ---
# Copy DATABASE_URL from ../backend/.env so the bot and website share one DB.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Server ---
PORT=3001
# 0.0.0.0 lets the (remote) Render backend reach the admin API for the
# website->WhatsApp booking notification. Use 127.0.0.1 if bot + backend share a host.
HOST=0.0.0.0
# Shared secret required on /admin/* routes — MUST match the backend's BOT_ADMIN_TOKEN.
ADMIN_TOKEN=change-me-to-match-backend

# --- Redis is optional; disabled here. Slot holds are enforced by a DB sweeper. ---
DISABLE_REDIS=true

# --- Minutes an unpaid booking is held before the slot is auto-released (60-120) ---
HOLD_MINUTES=90

# --- Chrome/Chromium path for whatsapp-web.js ---
# Linux VM (this setup): /usr/bin/google-chrome-stable
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_PATH=/usr/bin/google-chrome-stable

# Set true to boot the admin API without the WhatsApp client (e.g. for migrations)
DISABLE_WHATSAPP=false
